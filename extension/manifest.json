{
  "manifest_version": 3,
  "name": "bijouxdrain",
  "version": "1.0",
  "description": "Bijoux-branded overlay for throne.com/bijoux: floating images and a one-tap gift menu. Nothing automated - you stay in control.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://throne.com/*",
    "https://*.up.railway.app/*"
  ],
  "action": {
    "default_title": "Toggle bijouxdrain overlay",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://throne.com/bijoux*"],
      "css": ["overlay.css"],
      "js": ["config.js", "overlay.js"],
      "run_at": "document_idle"
    }
  ]
}
